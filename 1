        <!-- Секция трендов и аналитики рынка 2026 -->
        <section class="trends-panel" style="background: #090d16; border: 1px solid #1e293b; border-radius: 24px; padding: 32px; margin-bottom: 64px;">
            <h3 style="margin-top:0; font-size:22px; color:#ffffff;">Аналитика рынка и структура бюджетов на 2026 год</h3>
            <p style="font-size:13px; color:#6b7280; margin:4px 0 24px 0;">Статистический анализ распределения расходов крупных корпоративных заказчиков при планировании событий под ключ</p>
            
            <div class="bar-chart">
