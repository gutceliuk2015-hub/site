    <script>
        // Анимация сканирования для CSS графики
        const styleSheet = document.createElement("style");
        styleSheet.innerText = `@keyframes scanMove { 0% { transform: translateX(-100%); } 100% { transform: translateX(100%); } }`;
        document.head.appendChild(styleSheet);

        // Умная система расчета сметы по тарифам рынка 2026 года
        function smartCalculate() {
            const formatRates = {
                conference: 350000,
                gala: 600000,
                team: 450000
            };

            const tariffMultipliers = {
                basic: 1.0,
                business: 1.7,
                premium: 3.2
            };

            const eventType = document.getElementById('eventType').value;
            const tariff = document.getElementById('tariff').value;
            const guests = parseInt(document.getElementById('guestCount').value) || 0;
            const days = parseInt(document.getElementById('duration').value);

            // Базовый расчет от объема гостей и формата
            let baseRate = formatRates[eventType];
            let perGuestCost = baseRate / 100; 
                        // Итоговая формула: Расход на гостей * Коэффициент пакета * Коэффициент дней
            let calculatedCost = perGuestCost * guests * tariffMultipliers[tariff] * (1 + (days - 1) * 0.5);

            // Умная система скидок от объема (рыночный стандарт 2026 года)
            let discountPercent = 0;
            if (guests >= 300 && guests < 500) discountPercent = 5; // 5% скидка на продакшн при крупных объемах
            if (guests >= 500) discountPercent = 10; // 10% скидка на объемы от 500 человек

            let discountAmount = calculatedCost * (discountPercent / 100);
            calculatedCost = calculatedCost - discountAmount;

            // Налоговая составляющая (НДС 20% или УСН — заложим средний коэффициент обеспечения)
            let taxAmount = calculatedCost * 0.20;
            let finalTotal = calculatedCost + taxAmount;

            // Ограничение минимального бюджета для сохранения рентабельности команды
            if (finalTotal < 150000) finalTotal = 150000;

            // Вывод главной стоимости на экран
            document.getElementById('totalPrice').innerText = Math.round(finalTotal).toLocaleString('ru-RU') + ' ₽';

            // Динамическая генерация подробной детализации сметы
            const descBlock = document.getElementById('priceComposition');
            let formatText = eventType === 'conference' ? 'Бизнес-конференция' : eventType === 'gala' ? 'Гала-ужин' : 'Тимбилдинг';
            let tariffText = tariff === 'basic' ? 'Базовый пакет оборудования' : tariff === 'business' ? 'Бизнес-пакет (сцена + режиссер)' : 'Премиум-пакет (VIP + шоу)';

            let breakdownHTML = `
                <div style="text-align: left; margin-top: 16px; border-top: 1px dashed #1f2937; pt-16px; font-size: 13px; color: #9ca3af; line-height: 1.6;">
                    <strong style="color: #ffffff; display: block; margin-bottom: 8px;">Детализация автоматической калькуляции:</strong>
                    • Формат: ${formatText}<br>
                    • Категория: ${tariffText}<br>
                    • Масштаб: ${guests} участников (${days} дн.)<br>
                    ${discountPercent > 0 ? `• Персональная скидка за объем: <span style="color: #10b85c;">-${discountPercent}% (-${Math.round(discountAmount).toLocaleString('ru-RU')} ₽)</span><br>` : ''}
                    • Включая обязательный НДС (20%): ${Math.round(taxAmount).toLocaleString('ru-RU')} ₽<br>
                    <div style="margin-top: 12px; display: flex; justify-content: center;">
                        <button onclick="downloadPDFSpecification()" style="background: rgba(34, 211, 238, 0.1); border: 1px solid #22d3ee; color: #22d3ee; padding: 8px 16px; border-radius: 8px; font-size: 12px; font-weight: 600; cursor: pointer; transition: all 0.2s;">
                            <i class="fas fa-file-pdf" style="margin-right: 6px;"></i> Скачать официальную смету .PDF
                        </button>
                    </div>
                </div>
            `;
            descBlock.innerHTML = breakdownHTML;
        }

        // Логика симуляции скачивания PDF-спецификации (без внешних библиотек)
        function downloadPDFSpecification() {
            const price = document.getElementById('totalPrice').innerText;
            const eventType = document.getElementById('eventType').value;
            const tariff = document.getElementById('tariff').value;
            const guests = document.getElementById('guestCount').value;
            const days = document.getElementById('duration').value;

            // Генерируем чистое текстовое представление официального документа
            let docContent = `
==================================================
              OFFICIAL COMMERCIAL QUOTE
                    EVENT.ENGINE
==================================================
Дата генерации: ${new Date().toLocaleDateString('ru-RU')}
Спецификация бюджета для корпоративного заказчика

ПАРАМЕТРЫ ПРОЕКТА:
--------------------------------------------------
- Формат события: ${eventType.toUpperCase()}
- Выбранный тариф: ${tariff.toUpperCase()}
