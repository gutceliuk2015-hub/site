                    <div class="css-graphic-container" style="background: #120b24;">
                        <div class="geo-cube"></div>
                        <div class="geo-cube-secondary" style="position: absolute; top: 45%; left: 48%; width: 35px; height: 35px; border: 2px solid #6366f1; transform: rotate(25deg); background: rgba(99, 102, 241, 0.2);"></div>
                        <div class="scan-bar" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(135deg, transparent, rgba(168, 85, 247, 0.1), transparent); animation: scanMove 4s ease-in-out infinite;"></div>
