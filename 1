                            <input type="checkbox" id="mega_opt_${key}" value="${key}" onchange="smartCalculate()" style="accent-color: #06b6d4; width: 18px; height: 18px;">
                        </div>
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <span style="font-size: 12px; color: #06b6d4; font-family: monospace; font-weight: 700;">${priceLabel}</span>
                            <span style="font-size: 11px; color: #4b5563; text-transform: uppercase; letter-spacing: 0.5px;">Класс: ${opt.cat}</span>
                        </div>
                    </label>
                `;
            }

            optionsHTML += `</div>`;
            optionsSection.innerHTML = optionsHTML;

            const resultPanel = document.querySelector('.result-panel');
            if (resultPanel) {
                resultPanel.parentNode.insertBefore(optionsSection, resultPanel);
            }
        }

        // Глобальный расчет стоимости сметы
        const extendedCalculate = function() {
            initializeMultiPageSystem();

            const formatRates = { conference: 350000, gala: 600000, team: 450000 };
            const tariffMultipliers = { basic: 1.0, business: 1.7, premium: 3.2 };

            const eventType = document.getElementById('eventType').value;
            const tariff = document.getElementById('tariff').value;
            const guests = parseInt(document.getElementById('guestCount').value) || 0;
            const days = parseInt(document.getElementById('duration').value);

            let baseRate = formatRates[eventType];
            let perGuestCost = baseRate / 100; 

            let calculatedCost = perGuestCost * guests * tariffMultipliers[tariff] * (1 + (days - 1) * 0.5);

            let extraTotal = 0;
            let chosenServicesNames = [];

            for (let key in megaOptionsCatalog) {
                const cb = document.getElementById(`mega_opt_${key}`);
                const card = document.getElementById(`card_${key}`);
                
                if (cb && cb.checked) {
                    let cost = megaOptionsCatalog[key].price;
                    if (megaOptionsCatalog[key].perGuest) {
                        cost = cost * guests; 
                    }
                    extraTotal += cost;
                    chosenServicesNames.push(megaOptionsCatalog[key].name);
                    if (card) card.style.borderColor = '#06b6d4';
                } else {
                    if (card) card.style.borderColor = '#1f2937';
                }
            }

            calculatedCost += extraTotal;

            let discountPercent = guests >= 500 ? 10 : guests >= 300 ? 5 : 0;
            let discountAmount = calculatedCost * (discountPercent / 100);
            calculatedCost -= discountAmount;

            let taxAmount = calculatedCost * 0.20;
            let finalTotal = calculatedCost + taxAmount;

            if (finalTotal < 150000) finalTotal = 150000;

            document.getElementById('totalPrice').innerText = Math.round(finalTotal).toLocaleString('ru-RU') + ' ₽';

            const descBlock = document.getElementById('priceComposition');
            if (descBlock) {
                let optionsListText = chosenServicesNames.length > 0 ? chosenServicesNames.join(', ') : 'Не выбраны (базовая комплектация)';
                let formatText = eventType === 'conference' ? 'Бизнес-конференция' : eventType === 'gala' ? 'Гала-ужин' : 'Тимбилдинг';
                let tariffText = tariff === 'basic' ? 'Базовый пакет' : tariff === 'business' ? 'Бизнес-пакет' : 'Премиум-пакет';

                descBlock.innerHTML = `
                    <div style="text-align: left; margin-top: 20px; border-top: 1px dashed #1f2937; padding-top: 20px; font-size: 13px; color: #9ca3af; line-height: 1.6;">
                        <strong style="color: #ffffff; display: block; margin-bottom: 10px; font-size: 14px;">Спецификация ТЗ:</strong>
                        • Логистика: ${guests} человек (${days} дн.)<br>
                        • Формат: ${formatText} (${tariffText})<br>
                        • Опции: <span style="color: #22d3ee; font-weight:600;">${optionsListText}</span><br>
                        ${discountPercent > 0 ? `• Скидка: <span style="color: #10b85c;">-${discountPercent}% (-${Math.round(discountAmount).toLocaleString('ru-RU')} ₽)</span><br>` : ''}
                        • НДС (20%): ${Math.round(taxAmount).toLocaleString('ru-RU')} ₽<br>
                        <div style="margin-top: 20px; display: flex; flex-wrap: wrap; gap: 12px; justify-content: center;">
                            <button onclick="downloadPDFSpecification()" style="background: rgba(34, 211, 238, 0.05); border: 1px solid #22d3ee; color: #22d3ee; padding: 12px 24px; border-radius: 12px; font-size: 13px; font-weight: 600; cursor: pointer;">
                                <i class="fas fa-file-alt"></i> Скачать спецификацию (.TXT)
                            </button>
                            <button onclick="openLeadPopup()" style="background: linear-gradient(to right, #06b6d4, #4f46e5); border: none; color: #ffffff; padding: 12px 24px; border-radius: 12px; font-size: 13px; font-weight: 700; cursor: pointer; box-shadow: 0 4px 15px rgba(6,182,212,0.2);">
                                <i class="fas fa-check-double"></i> Отправить бриф инженеру
                            </button>
                        </div>
                    </div>
                `;
            }
        };

        smartCalculate = extendedCalculate;
        setTimeout(initializeMultiPageSystem, 50);
    </script>
</body>
</html>
